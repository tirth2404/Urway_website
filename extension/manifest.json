{
  "manifest_version": 3,
  "name": "UrWay Focus Tracker",
  "version": "1.0.0",
  "description": "Tracks active tab URLs and study time for adaptive roadmap sync.",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "UrWay Tracker"
  }
}
